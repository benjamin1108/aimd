{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIMD Desktop",
  "version": "0.1.0",
  "identifier": "org.aimd.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AIMD Desktop",
        "width": 1180,
        "height": 820,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$TEMP/aimd-desktop-assets/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["aimd"],
        "name": "AIMD Document",
        "description": "AIMD document",
        "role": "Editor",
        "mimeType": "application/vnd.aimd",
        "rank": "Owner",
        "exportedType": {
          "identifier": "org.aimd.document",
          "conformsTo": ["public.data"]
        }
      },
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "rank": "Default"
      }
    ]
  }
}
