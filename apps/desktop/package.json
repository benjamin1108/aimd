{
  "name": "@aimd/desktop-tauri",
  "private": true,
  "version": "1.0.10",
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/sync-version.mjs",
    "dev": "npm run build:injector && tauri dev",
    "prebuild": "node ../../scripts/sync-version.mjs",
    "dev:web": "vite --host 127.0.0.1 --port 1420",
    "build": "npm run build:injector && tauri build",
    "prebuild:pkg": "node ../../scripts/sync-version.mjs",
    "build:pkg": "../../scripts/build-macos-pkg.sh",
    "build:web": "vite build",
    "build:injector": "esbuild src/webview/injector.ts --bundle --outfile=../dist/injector.js --format=iife --platform=browser --loader:.css=text",
    "prepare:pdf-sidecar": "node scripts/prepare-pdf-sidecar.mjs",
    "icon:prepare": "./scripts/prepare-icon.sh",
    "icon:update": "./scripts/update-tauri-icons.sh",
    "css:check": "node scripts/check-css-architecture.mjs",
    "size:check": "node scripts/check-code-size.mjs",
    "precheck": "node ../../scripts/sync-version.mjs --check",
    "check": "npm run build:injector && npm run typecheck && npm run css:check && npm run size:check",
    "test": "npm run check",
    "typecheck": "tsc --noEmit",
    "test:gemini": "node scripts/test-gemini.mjs",
    "test:gemini:rust": "cargo run --manifest-path src-tauri/Cargo.toml --bin test_gemini --",
    "test:e2e": "playwright test",
    "test:updater-telemetry": "node scripts/test-updater-telemetry.mjs",
    "test:e2e:vite": "node scripts/run-e2e-with-vite.mjs",
    "test:e2e:ui": "playwright test --ui",
    "icon:alpha": "node scripts/make-icon-transparent.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/turndown": "^5.0.6",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/mozilla-readability": "^0.2.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
