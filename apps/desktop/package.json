{
  "name": "@aimd/desktop-tauri",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:injector && tauri dev",
    "dev:web": "vite --host 127.0.0.1 --port 1420",
    "build": "npm run build:injector && tauri build",
    "build:web": "vite build",
    "build:injector": "esbuild src/webview/injector.ts --bundle --outfile=../dist/injector.js --format=iife --platform=browser",
    "prepare:pdf-sidecar": "node scripts/prepare-pdf-sidecar.mjs",
    "icon:prepare": "./scripts/prepare-icon.sh",
    "icon:update": "./scripts/update-tauri-icons.sh",
    "size:check": "node scripts/check-code-size.mjs",
    "check": "npm run typecheck && npm run size:check",
    "test": "npm run check",
    "typecheck": "tsc --noEmit",
    "test:gemini": "node scripts/test-gemini.mjs",
    "test:gemini:rust": "cargo run --manifest-path src-tauri/Cargo.toml --bin test_gemini --",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@tauri-apps/api": "^2.0.0",
    "@types/turndown": "^5.0.6",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/mozilla-readability": "^0.2.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
